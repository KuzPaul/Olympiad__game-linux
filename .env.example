# Скопируйте в .env и подставьте свои значения.
# Файл .env не коммитится в git.

# Секрет сессий Flask (в production — длинная случайная строка)
SECRET_KEY='your_secret_key'

# Пароль первого входа для учётной записи преподавателя (логин: admin).
# Задаётся один раз при создании записи в БД; сменить пароль можно в панели администратора.
ADMIN_INITIAL_PASSWORD='admin123'

# DATABASE_PATH в .env не задавайте: в Docker путь к БД прописан в docker-compose.yml
# (./docker-data на хосте → /app/db/olympiad_linux.db в контейнере).
